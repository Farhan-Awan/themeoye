{%- comment -%}
  Themeoye Product Media Snippet
  - Inputs:
    - product: Product object (required)
{%- endcomment -%}

<div class="product-media-gallery" data-media-layout="{{ settings.product_media_layout | default: 'gallery' }}">
  {% if product.media.size > 0 %}
    <div class="swiper themeoye-product-media-swiper">
      <div class="swiper-wrapper">
        {% for media in product.media %}
          <div class="swiper-slide" data-media-id="{{ media.id }}">
            {% case media.media_type %}
              {% when 'image' %}
                <div class="product-media-image-wrapper">
                  {{ media | image_url: width: 1200 | image_tag: 
                    loading: 'lazy', 
                    widths: '375, 550, 750, 1100, 1500', 
                    sizes: '(min-width: 990px) calc(50vw - 80px), 100vw',
                    class: 'product-media-image',
                    alt: media.alt | default: product.title | escape
                  }}
                </div>
              {% when 'video' or 'external_video' %}
                <div class="product-media-video-wrapper">
                  {{ media | video_tag: controls: true, autoplay: false, loop: true, class: 'product-media-video' }}
                </div>
              {% else %}
                <div class="product-media-model-wrapper">
                  {{ media | model_viewer_tag }}
                </div>
            {% endcase %}
          </div>
        {% endfor %}
      </div>
      
      {% if product.media.size > 1 %}
        <div class="swiper-button-prev"></div>
        <div class="swiper-button-next"></div>
        <div class="swiper-pagination"></div>
      {% endif %}
    </div>

    {% if product.media.size > 1 %}
      <div class="product-media-thumbnails">
        {% for media in product.media %}
          <button 
            class="product-media-thumbnail {% if forloop.first %}is-active{% endif %}" 
            type="button" 
            aria-label="View media {{ forloop.index }}"
            data-index="{{ forloop.index0 }}"
          >
            {{ media | image_url: width: 120 | image_tag: loading: 'lazy', class: 'product-thumbnail-image', alt: media.alt | escape }}
          </button>
        {% endfor %}
      </div>
    {% endif %}

  {% else %}
    <div class="product-media-placeholder">
      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
    </div>
  {% endif %}
</div>

<style>
  .product-media-gallery {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    position: relative;
  }
  .themeoye-product-media-swiper {
    width: 100%;
    background: var(--color-background-2);
    border-radius: var(--border-radius-card);
    overflow: hidden;
  }
  .product-media-image-wrapper, 
  .product-media-video-wrapper, 
  .product-media-model-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 1/1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .product-media-image, 
  .product-media-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .product-media-thumbnails {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .product-media-thumbnail {
    width: 60px;
    height: 60px;
    border-radius: var(--border-radius-badge);
    border: 1px solid var(--color-border);
    background: var(--color-background);
    padding: 2px;
    cursor: pointer;
    overflow: hidden;
    transition: border-color var(--duration-fast) var(--easing-default);
  }
  .product-media-thumbnail:hover, 
  .product-media-thumbnail.is-active {
    border-color: var(--color-border-strong);
  }
  .product-thumbnail-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

<script>
  function initProductMedia() {
    const swiperEl = document.querySelector('.themeoye-product-media-swiper');
    if (!swiperEl || typeof Swiper === 'undefined') return;

    if (swiperEl.swiperInstance) return;

    const mediaSwiper = new Swiper(swiperEl, {
      slidesPerView: 1,
      spaceBetween: 0,
      loop: false,
      pagination: {
        el: swiperEl.querySelector('.swiper-pagination'),
        clickable: true
      },
      navigation: {
        nextEl: swiperEl.querySelector('.swiper-button-next'),
        prevEl: swiperEl.querySelector('.swiper-button-prev')
      }
    });

    swiperEl.swiperInstance = mediaSwiper;

    const thumbs = document.querySelectorAll('.product-media-thumbnail');
    thumbs.forEach(thumb => {
      thumb.addEventListener('click', () => {
        const index = parseInt(thumb.dataset.index, 10);
        mediaSwiper.slideTo(index);
      });
    });

    mediaSwiper.on('slideChange', () => {
      thumbs.forEach((t, i) => {
        t.classList.toggle('is-active', i === mediaSwiper.activeIndex);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProductMedia);
  } else {
    initProductMedia();
  }

  document.addEventListener('shopify:section:load', function(event) {
    if (event.target.querySelector('.themeoye-product-media-swiper')) {
      initProductMedia();
    }
  });
</script>
