{%- comment -%}
Themeoye Footer Section
- Multi-column, social links, copyright
- Follows section schema and output pattern from master brief
{%- endcomment -%}

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "container_size", "label": "Container size", "options": [ { "value": "default", "label": "Default" }, { "value": "narrow", "label": "Narrow" }, { "value": "wide", "label": "Wide" }, { "value": "full", "label": "Full width" } ], "default": "default" },
    { "type": "color", "id": "background", "label": "Section background", "default": "#0F0F0F" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" },
    { "type": "select", "id": "columns", "label": "Footer columns", "options": [ { "value": "2", "label": "2 columns" }, { "value": "3", "label": "3 columns" }, { "value": "4", "label": "4 columns" } ], "default": "3" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding top (mobile)", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 32 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bottom (mobile)", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 32 }
  ],
  "presets": [ { "name": "Footer", "category": "Footer" } ]
}
{% endschema %}

{% style %}
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.background }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

<footer class="footer container container--{{ section.settings.container_size }}" role="contentinfo">
  <div class="footer__columns footer__columns--{{ section.settings.columns }}">
    <div class="footer__column">
      <h2>{{ shop.name }}</h2>
      <p>{{ 'footer.copyright' | t: year: "now" }}</p>
    </div>
    <div class="footer__column">
      <h3>{{ 'footer.social_follow' | t }}</h3>
      <ul class="footer__social">
        {% if settings.social_facebook %}<li><a href="{{ settings.social_facebook }}" target="_blank" rel="noopener">Facebook</a></li>{% endif %}
        {% if settings.social_instagram %}<li><a href="{{ settings.social_instagram }}" target="_blank" rel="noopener">Instagram</a></li>{% endif %}
        {% if settings.social_twitter %}<li><a href="{{ settings.social_twitter }}" target="_blank" rel="noopener">Twitter/X</a></li>{% endif %}
        {% if settings.social_youtube %}<li><a href="{{ settings.social_youtube }}" target="_blank" rel="noopener">YouTube</a></li>{% endif %}
        {% if settings.social_pinterest %}<li><a href="{{ settings.social_pinterest }}" target="_blank" rel="noopener">Pinterest</a></li>{% endif %}
        {% if settings.social_tiktok %}<li><a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener">TikTok</a></li>{% endif %}
        {% if settings.social_linkedin %}<li><a href="{{ settings.social_linkedin }}" target="_blank" rel="noopener">LinkedIn</a></li>{% endif %}
        {% if settings.social_snapchat %}<li><a href="{{ settings.social_snapchat }}" target="_blank" rel="noopener">Snapchat</a></li>{% endif %}
        {% if settings.social_whatsapp %}<li><a href="{{ settings.social_whatsapp }}" target="_blank" rel="noopener">WhatsApp</a></li>{% endif %}
        {% if settings.social_telegram %}<li><a href="{{ settings.social_telegram }}" target="_blank" rel="noopener">Telegram</a></li>{% endif %}
        {% if settings.social_discord %}<li><a href="{{ settings.social_discord }}" target="_blank" rel="noopener">Discord</a></li>{% endif %}
        {% if settings.social_messenger %}<li><a href="{{ settings.social_messenger }}" target="_blank" rel="noopener">Messenger</a></li>{% endif %}
      </ul>
    </div>
    <div class="footer__column">
      <h3>Links</h3>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/collections">Collections</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/account">Account</a></li>
      </ul>
    </div>
  </div>
</footer>
