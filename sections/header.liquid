{%- comment -%}
Themeoye Header Section
- Sticky, transparent, logo, navigation, search, dark mode toggle
- Mega menu and search via snippets
- Follows section schema and output pattern from master brief
{%- endcomment -%}

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "container_size", "label": "Container size", "options": [ { "value": "default", "label": "Default" }, { "value": "narrow", "label": "Narrow" }, { "value": "wide", "label": "Wide" }, { "value": "full", "label": "Full width" } ], "default": "default" },
    { "type": "color", "id": "background", "label": "Section background", "default": "#FFFFFF" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding top (mobile)", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bottom (mobile)", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 0 },
    { "type": "checkbox", "id": "sticky", "label": "Sticky header", "default": true },
    { "type": "checkbox", "id": "transparent_home", "label": "Transparent on home page", "default": true },
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "range", "id": "logo_max_width", "label": "Logo max width", "min": 60, "max": 320, "step": 4, "unit": "px", "default": 160 },
    { "type": "checkbox", "id": "show_dark_mode_toggle", "label": "Show dark mode toggle", "default": true }
  ],
  "presets": [ { "name": "Header", "category": "Header" } ]
}
{% endschema %}

{% style %}
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.background }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

<header class="header container container--{{ section.settings.container_size }}" role="banner">
  <div class="header__inner">
    <a href="/" class="header__logo" style="max-width: {{ section.settings.logo_max_width }}px">
      {% if section.settings.logo != blank %}
        <img src="{{ section.settings.logo | image_url: width: 320 }}" alt="{{ shop.name }}" style="max-width: 100%; height: auto;">
      {% else %}
        <span class="header__logo-text">{{ shop.name }}</span>
      {% endif %}
    </a>
    <nav class="header__nav" role="navigation" aria-label="Main navigation">
      {% render 'header-mega-menu' %}
    </nav>
    <div class="header__actions">
      {% render 'header-search' %}
      {% if section.settings.show_dark_mode_toggle %}
        <button class="header__dark-toggle" data-dark-mode-toggle aria-label="Toggle dark mode">
          <span aria-hidden="true">🌙</span>
        </button>
      {% endif %}
      <a href="/account" class="header__account" aria-label="Account">👤</a>
      <a href="/cart" class="header__cart" aria-label="Cart">🛒</a>
    </div>
  </div>
</header>
