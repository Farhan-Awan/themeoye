{%- comment -%}
Themeoye Product Card snippet
- Used in product grid, quick add, price, badges
{%- endcomment -%}

<div class="card card-product">
  <a href="{{ product.url }}" class="card-product__image">
    {%- if product.featured_image -%}
      <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" width="300" height="400" loading="lazy">
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
    {%- if product.available == false -%}
      <span class="badge badge--sale">{{ 'product.sold_out' | t }}</span>
    {%- elsif product.compare_at_price > product.price -%}
      <span class="badge badge--sale">{{ 'product.sale' | t }}</span>
    {%- endif -%}
    {%- if product.tags contains 'new' -%}
      <span class="badge badge--new">{{ 'product.new' | t }}</span>
    {%- endif -%}
  </a>
  <div class="card-product__info">
    <h3 class="card-product__title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
    <div class="card-product__price">{% render 'price', product: product %}</div>
    <div class="card-product__quick-add">{% render 'quick-add', product: product %}</div>
  </div>
</div>
