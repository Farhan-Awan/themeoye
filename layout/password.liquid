{%- comment -%}
Themeoye password (coming soon) layout
- Minimal, centered password form
- Loads head tags, css-variables, base/theme CSS
{%- endcomment -%}

<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" data-theme="{{ settings.color_scheme_default }}" class="no-js">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_background }}">
    <title>{{ 'general.password_page.title' | t }}</title>
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
    {%- render 'css-variables' -%}
    <link rel="stylesheet" href="{{ 'base.css' | asset_url }}">
    <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}">
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
    <script src="{{ 'dark-mode.js' | asset_url }}" defer></script>
    <script src="{{ 'animations.js' | asset_url }}" defer></script>
    {{ content_for_header }}
  </head>
  <body class="password-page">
    <main id="MainContent" role="main" tabindex="-1">
      <div class="container" style="min-height: 100vh; display: flex; align-items: center; justify-content: center; flex-direction: column;">
        <h1>{{ 'general.password_page.heading' | t }}</h1>
        <div class="password-form">
          {{ content_for_layout }}
        </div>
      </div>
    </main>
  </body>
</html>
