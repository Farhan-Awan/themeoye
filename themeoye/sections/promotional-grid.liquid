{%- comment -%}
Themeoye Promotional Grid Section
- Grid of promotional tiles, images, links
{%- endcomment -%}

{% schema %}
{
  "name": "Promotional Grid",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "container_size", "label": "Container size", "options": [ { "value": "default", "label": "Default" }, { "value": "narrow", "label": "Narrow" }, { "value": "wide", "label": "Wide" }, { "value": "full", "label": "Full width" } ], "default": "default" },
    { "type": "color_background", "id": "background", "label": "Section background" },
    { "type": "range", "id": "columns", "label": "Columns", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding top (mobile)", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bottom (mobile)", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 48 }
  ],
  "blocks": [
    { "type": "tile", "name": "Tile", "settings": [
      { "type": "image_picker", "id": "image", "label": "Tile image" },
      { "type": "text", "id": "heading", "label": "Heading" },
      { "type": "url", "id": "link", "label": "Link" }
    ] }
  ],
  "max_blocks": 8,
  "presets": [ { "name": "Promotional Grid", "category": "Image" } ]
}
{% endschema %}

{% style %}
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.background }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

<section class="promotional-grid container container--{{ section.settings.container_size }}">
  <div class="grid" style="grid-template-columns: repeat({{ section.settings.columns }}, 1fr);">
    {% for block in section.blocks %}
      <div class="promotional-grid__tile" data-animate style="transition-delay: {{ forloop.index | times: 100 }}ms;">
        {% if block.settings.image != blank %}
          <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.heading | escape }}" loading="lazy">
        {% endif %}
        <h3>{{ block.settings.heading }}</h3>
        {% if block.settings.link %}<a href="{{ block.settings.link }}" class="button">View</a>{% endif %}
      </div>
    {% endfor %}
  </div>
</section>
