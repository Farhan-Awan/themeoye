{%- comment -%}
  Themeoye Cart Drawer Section
  - Fully reactive sliding AJAX drawer wrapped in <cart-drawer> custom element
  - Supports live item loops, dynamic quantity modifiers, subtotaling, and notes
{%- endcomment -%}

<cart-drawer class="drawer {% if cart == empty %}is-empty{% endif %}" id="CartDrawer">
  <div class="drawer__inner">
    <div class="drawer__header">
      <h2 class="drawer__heading">Shopping Cart</h2>
      <button class="drawer__close-btn" type="button" onclick="this.closest('cart-drawer').close()" aria-label="Close cart drawer">
        {% render 'icon-close' %}
      </button>
    </div>

    {% comment %} Active Cart State {% endcomment %}
    <div class="drawer__content">
      {% if cart != empty %}
        <div class="drawer__items-wrapper">
          <table class="drawer__items" role="table">
            <tbody role="rowgroup">
              {%- for item in cart.items -%}
                <tr class="drawer__item" id="CartDrawer-Item-{{ item.index | plus: 1 }}" role="row" data-line-item-key="{{ item.key }}">
                  
                  <td class="drawer__item-media" role="cell">
                    {% if item.image %}
                      <a href="{{ item.url }}">
                        <img class="drawer__item-img" src="{{ item.image | image_url: width: 120 }}" alt="{{ item.image.alt | escape }}" loading="lazy" width="60" height="60">
                      </a>
                    {% endif %}
                  </td>

                  <td class="drawer__item-details" role="cell">
                    <a href="{{ item.url }}" class="drawer__item-title">{{ item.product.title }}</a>
                    
                    {%- unless item.product.has_only_default_variant -%}
                      <p class="drawer__item-variant">{{ item.variant.title }}</p>
                    {%- endunless -%}

                    <div class="drawer__item-price">
                      {%- if item.original_price != item.final_price -%}
                        <span class="price price--sale">{{ item.final_price | money }}</span>
                        <span class="price price--compare">{{ item.original_price | money }}</span>
                      {%- else -%}
                        <span class="price">{{ item.original_price | money }}</span>
                      {%- endif -%}
                    </div>

                    <div class="drawer__item-controls">
                      {% render 'quantity-input', 
                        value: item.quantity, 
                        name: 'updates[]', 
                        id: 'Updates-' | append: item.index | plus: 1,
                        min: 0
                      %}
                      
                      <a href="/cart/change?line={{ item.index | plus: 1 }}&quantity=0" class="drawer__item-remove" data-remove-key="{{ item.key }}" aria-label="Remove item">
                        Remove
                      </a>
                    </div>
                  </td>
                  
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        </div>
      {% else %}
        {% comment %} Empty Cart State {% endcomment %}
        <div class="drawer__empty text-center">
          <p class="drawer__empty-text">Your cart is empty.</p>
          <a href="/collections/all" class="button button--primary drawer__empty-btn">Continue Shopping</a>
        </div>
      {% endif %}
    </div>

    {% comment %} Drawer Footer {% endcomment %}
    {% if cart != empty %}
      <div class="drawer__footer">
        {%- if settings.cart_note -%}
          <details class="drawer__note-toggle">
            <summary>Add order note</summary>
            <textarea name="note" class="drawer__note-input" placeholder="Special instructions for your order...">{{ cart.note }}</textarea>
          </details>
        {%- endif -%}

        <div class="drawer__totals">
          <span class="drawer__totals-label">Subtotal</span>
          <span class="drawer__totals-price">{{ cart.total_price | money }}</span>
        </div>

        <small class="drawer__tax-note">
          Taxes and shipping calculated at checkout.
        </small>

        <div class="drawer__actions">
          <form action="/cart" method="post" id="CartDrawer-Form">
            <button type="submit" name="checkout" class="button button--full-width drawer__checkout-btn">
              Proceed to Checkout
            </button>
          </form>
        </div>
      </div>
    {% endif %}

  </div>
</cart-drawer>

<style>
  cart-drawer {
    position: fixed;
    top: 0; right: 0; bottom: 0; left: 0;
    z-index: var(--z-drawer, 400);
    display: flex;
    justify-content: flex-end;
    background: var(--color-overlay);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-normal) var(--easing-default);
  }
  cart-drawer.is-active {
    opacity: 1;
    pointer-events: auto;
  }
  .drawer__inner {
    width: 100%;
    max-width: {{ section.settings.width | default: 400 }}px;
    height: 100%;
    background: {{ section.settings.background | default: 'var(--color-background)' }};
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-xl);
    transform: translateX(100%);
    transition: transform var(--duration-normal) var(--easing-default);
  }
  cart-drawer.is-active .drawer__inner {
    transform: translateX(0);
  }
  .drawer__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .drawer__heading {
    margin: 0;
    font-size: var(--font-size-2xl, 1.5rem);
    font-family: var(--font-heading-family);
  }
  .drawer__close-btn {
    color: var(--color-foreground);
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    padding: 0.5rem;
  }
  .drawer__content {
    flex-grow: 1;
    overflow-y: auto;
    padding: 1.5rem;
  }
  .drawer__items {
    width: 100%;
    border-collapse: collapse;
  }
  .drawer__item {
    display: flex;
    gap: 1rem;
    padding-bottom: 1.5rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .drawer__item-media {
    flex-shrink: 0;
    width: 70px;
    height: 70px;
    border-radius: var(--border-radius-badge);
    overflow: hidden;
    background: var(--color-background-2);
  }
  .drawer__item-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .drawer__item-details {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .drawer__item-title {
    font-weight: bold;
    font-size: var(--font-size-md, 1rem);
    color: var(--color-foreground);
  }
  .drawer__item-variant {
    font-size: var(--font-size-xs, 0.75rem);
    color: var(--color-foreground-secondary);
    margin: 0;
  }
  .drawer__item-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.5rem;
  }
  .drawer__item-remove {
    font-size: var(--font-size-xs, 0.75rem);
    text-decoration: underline;
    color: var(--color-foreground-secondary);
  }
  
  /* Footer styles */
  .drawer__footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem;
    background: var(--color-background-2);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .drawer__totals {
    display: flex;
    justify-content: space-between;
    font-weight: bold;
    font-size: var(--font-size-lg, 1.125rem);
  }
  .drawer__tax-note {
    font-size: var(--font-size-xs, 0.75rem);
    color: var(--color-foreground-secondary);
  }
  .drawer__checkout-btn {
    height: 48px;
  }
  
  /* Empty state */
  .drawer__empty {
    padding: 4rem 1rem;
  }
  .drawer__empty-text {
    font-size: var(--font-size-lg, 1.125rem);
    color: var(--color-foreground-secondary);
    margin-bottom: 2rem;
  }
  .drawer__empty-btn {
    display: inline-block;
  }
</style>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "color_background", "id": "background", "label": "Drawer background" },
    { "type": "range", "id": "width", "label": "Drawer width (px)", "min": 320, "max": 600, "step": 10, "default": 400 }
  ],
  "presets": [ { "name": "Cart Drawer", "category": "Cart" } ]
}
{% endschema %}
